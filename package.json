{
  "name": "pern-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "A personal portfolio website built with PostgreSQL, Express, React, and Node.",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "client": "vite",
    "server": "node server/index.js",
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "4.21.2",
    "pg": "^8.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.1.2",
    "vite": "^7.0.0"
  }
}
